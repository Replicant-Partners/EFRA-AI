generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Analysis {
  id          String      @id @default(cuid())
  ticker      String
  analyst_id  String
  catalyst    String
  mode        String
  status      String
  full_state     Json
  report_content Json?
  rating         String?
  pt_12m      Float?
  sector      String?
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  intel_items IntelItem[]
  episodes          Episode[]
  evalRuns          EvalRun[]
  timelineEntries   TimelineEntry[]
  syntheticEpisodes SyntheticEpisode[]

  @@index([ticker])
  @@index([created_at])
  @@index([rating])
  @@index([status])
}

// ─── Episode Store ────────────────────────────────────────────────────────────
// Inspired by the Social Agent Observability Platform logical architecture.
// Each agent step in each pipeline run produces one Episode.
// Analyst approvals produce episodes with higher authority_weight than
// auto-generated ones — human evidence outweighs machine evidence.

model Episode {
  id                    String   @id @default(cuid())

  // Foreign key to the analysis this episode belongs to
  analysis_id           String
  analysis              Analysis @relation(fields: [analysis_id], references: [id], onDelete: Cascade)

  // Who and what
  analyst_id            String
  ticker                String
  agent                 String   // "scout" | "intel" | "forensic_pre" | "cf" | "forensic" | "valuation" | "kata" | "communication" | "lens"

  // The "query" is the input the agent received (serialized context summary)
  // The "response" is the structured output the agent produced
  query                 String   @db.Text
  response              Json

  // Provenance — where did this episode come from?
  // "auto_pass"         : agent ran and analyst approved without modification
  // "auto_drop"         : agent triggered a DROP/BLOCK gate
  // "human_approved"    : analyst explicitly reviewed and approved
  // "human_corrected"   : analyst added a note/correction before continuing
  // "synthetic"         : created by the system as a correction record (future)
  provenance            String   @default("auto_pass")

  // Authority weight — how much epistemic weight does this episode carry?
  // auto_pass     → 0.5  (machine generated, not reviewed)
  // human_approved→ 0.8  (human saw it and said OK)
  // human_corrected→1.0  (human actively modified it — highest authority)
  // auto_drop     → 0.3  (pipeline rejected it — low signal)
  authority_weight      Float    @default(0.5)

  // Agent output scores (denormalized for fast queries — no JSON parsing needed)
  alpha_score           Float?
  risk_score            Float?
  confidence            Float?
  rr_ratio              Float?
  enter_score           Float?
  process_confidence    Float?
  lens_verdict          String?
  loop_score            Float?
  dk_flag               String?

  // Analyst note added at approval time (null = no note)
  analyst_note          String?  @db.Text

  // Pipeline persona version — increments when system prompt of any agent changes
  // Allows drift detection across pipeline versions
  pipeline_version      Int      @default(1)

  corrections           EpisodeCorrection[]

  created_at            DateTime @default(now())

  @@index([analysis_id])
  @@index([analyst_id])
  @@index([ticker])
  @@index([agent])
  @@index([provenance])
  @@index([created_at])
}

// ─── Two-Write Memory — Plane D completion ───────────────────────────────────
// EpisodeCorrection: immutable record of reviewer correction + coherence gate result.
// SyntheticEpisode: high-authority episode created from the correction,
//                   re-injected into Episode Store to close the feedback loop.

model EpisodeCorrection {
  id                 String           @id @default(cuid())

  episode_id         String
  episode            Episode          @relation(fields: [episode_id], references: [id], onDelete: Cascade)

  anomaly_event_id   String
  anomaly_event      AnomalyEvent     @relation(fields: [anomaly_event_id], references: [id], onDelete: Cascade)

  reviewer_id        String

  // "episode" | "dyad" | "agent_wide"
  scope              String           @default("episode")

  // "factual_error" | "reasoning_gap" | "calibration_bias" | "style_issue"
  classification     String

  correction_text    String           @db.Text
  dimension          String?

  // Coherence Gate outcome
  gamma              Float            // Γ(C) 0.0–1.0; must be >= 0.5 to proceed
  gate_verdict       String           // "approved" | "settled" | "blocked"
  tensions           Json             @default("[]")
  minimum_update_set Json             @default("[]")

  authority_weight   Float            @default(1.0)

  synthetic_episode  SyntheticEpisode?

  created_at         DateTime         @default(now())

  @@index([episode_id])
  @@index([anomaly_event_id])
  @@index([reviewer_id])
  @@index([scope])
}

model SyntheticEpisode {
  id                  String            @id @default(cuid())

  correction_id       String            @unique
  correction          EpisodeCorrection @relation(fields: [correction_id], references: [id], onDelete: Cascade)

  analysis_id         String
  analysis            Analysis          @relation(fields: [analysis_id], references: [id], onDelete: Cascade)

  corrected_response  Json
  authority_weight    Float             @default(1.0)
  provenance          String            @default("synthetic")
  agent               String
  analyst_id          String
  ticker              String

  created_at          DateTime          @default(now())

  @@index([correction_id])
  @@index([analysis_id])
  @@index([analyst_id])
  @@index([agent])
}

// ─── Longitudinal Observer — Plane C ─────────────────────────────────────────
// TimelineEntry: denormalized read surface, one per EvalRun.
// AnomalyEvent: raised when the timeline reveals drift/conflict/rupture/safety.
// AgentObservabilityState: per-analyst checkpoint for Background Worker.

model TimelineEntry {
  id               String   @id @default(cuid())

  analysis_id      String
  analysis         Analysis @relation(fields: [analysis_id], references: [id], onDelete: Cascade)
  eval_run_id      String
  eval_run         EvalRun  @relation(fields: [eval_run_id], references: [id], onDelete: Cascade)
  analyst_id       String
  ticker           String

  // Per-dimension scores from AggregatedSignal (denormalized for fast reads)
  // Shape: { argument_quality, scenario_coherence, probability_calibration, overall }
  dim_scores       Json     @default("{}")

  // Drift norm: distance from rolling mean (0.0 = no drift). Set by Background Worker.
  drift_norm       Float    @default(0.0)

  // Anomaly flags: e.g. "drift:anomalous", "conflict:argument_quality", "safety:low_overall"
  anomaly_flags    String[] @default([])

  // Where did this entry come from?
  provenance       String   @default("eval_run") // "eval_run" | "backfill" | "correction"

  pipeline_version Int      @default(1)

  // Has the Background Worker processed this entry?
  worker_processed Boolean  @default(false)

  anomalies        AnomalyEvent[]

  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@index([analysis_id])
  @@index([eval_run_id])
  @@index([analyst_id])
  @@index([ticker])
  @@index([created_at])
  @@index([worker_processed])
}

model AnomalyEvent {
  id                String        @id @default(cuid())
  analyst_id        String
  ticker            String
  timeline_entry_id String
  timeline_entry    TimelineEntry @relation(fields: [timeline_entry_id], references: [id], onDelete: Cascade)

  // "drift" | "conflict" | "rupture" | "safety"
  kind              String
  // "low" | "medium" | "high" | "critical"
  severity          String        @default("medium")

  // Context payload: dimension, score, threshold, window size, etc.
  payload           Json          @default("{}")

  // Feeds Plane D HITL queue
  requires_review   Boolean       @default(true)

  // Resolution (set by Plane D reviewer)
  resolved_at       DateTime?
  resolved_by       String?

  corrections       EpisodeCorrection[]

  created_at        DateTime      @default(now())

  @@index([analyst_id])
  @@index([ticker])
  @@index([kind])
  @@index([requires_review])
  @@index([resolved_at])
  @@index([timeline_entry_id])
}

model AgentObservabilityState {
  id                     String    @id @default(cuid())
  analyst_id             String    @unique

  // Incremental scan checkpoint
  last_scanned_entry_id  String?

  // Counters
  total_entries_scanned  Int       @default(0)
  total_anomalies_raised Int       @default(0)
  total_analyses         Int       @default(0)

  // Rolling means per dimension (updated by Background Worker)
  // Shape: { argument_quality, scenario_coherence, probability_calibration, overall }
  rolling_means          Json      @default("{}")

  last_worker_run_at     DateTime?

  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt
}

// ─── Evaluator Registry — Plane B ────────────────────────────────────────────
// Inspired by the Social Agent Observability Platform logical architecture.
// One EvalRun per completed analysis; one EvalSignal per evaluator × dimension.
// Three LLM-as-judge evaluators run after each analysis is saved:
//   1. argument_quality       — thesis structure and evidence quality
//   2. scenario_coherence     — Bull/Base/Bear internal consistency
//   3. probability_calibration — scenario probability realism

model EvalRun {
  id                  String       @id @default(cuid())
  analysis_id         String
  analysis            Analysis     @relation(fields: [analysis_id], references: [id], onDelete: Cascade)
  ticker              String
  analyst_id          String

  // Aggregated confidence-weighted mean per dimension
  // Shape: { argument_quality: float, scenario_coherence: float, probability_calibration: float }
  aggregated_signal   Json         @default("{}")

  // Simple mean of all dimension means (0.0–1.0)
  overall_score       Float?

  // Was a pre-filter triggered? (reserved for future safety checks)
  prefilter_blocked   Boolean      @default(false)

  // Dimensions where evaluators disagreed (score spread > 0.3)
  conflict_flags      String[]     @default([])

  signals             EvalSignal[]
  timelineEntries     TimelineEntry[]
  created_at          DateTime     @default(now())

  @@index([analysis_id])
  @@index([ticker])
  @@index([created_at])
}

model EvalSignal {
  id              String   @id @default(cuid())
  eval_run_id     String
  eval_run        EvalRun  @relation(fields: [eval_run_id], references: [id], onDelete: Cascade)
  analysis_id     String

  // Which evaluator produced this signal
  evaluator_name  String   // "argument_quality" | "scenario_coherence" | "probability_calibration"

  // Behavioral dimension (matches evaluator_name 1:1 in v1)
  dimension       String

  // LLM judge output
  score           Float    // 0.0–1.0
  confidence      Float    // 0.0–1.0
  rationale       String?  @db.Text

  // Full raw JSON response for auditability
  raw_response    Json?

  created_at      DateTime @default(now())

  @@index([eval_run_id])
  @@index([analysis_id])
  @@index([evaluator_name])
  @@index([dimension])
}

model IntelItem {
  id                String   @id @default(cuid())
  analysis_id       String
  analysis          Analysis @relation(fields: [analysis_id], references: [id], onDelete: Cascade)
  content           String
  impact_area       String?
  sector            String?
  severity          String?
  summary           String?
  include_in_report Boolean  @default(false)
  created_at        DateTime @default(now())

  @@index([analysis_id])
}
